
generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum DifficultyLevel {
  VERY_EASY
  EASY
  MEDIUM
  DIFFICULT
  VERY_DIFFICULT
}

enum LernpfadDifficulty {
  ANFAENGER
  FORTGESCHRITTEN
  PRO
}

enum QuestionKind {
  MC_SINGLE
  FILL_BLANK
  SHORT_TEXT
  MATH
  DRAG_DROP
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  NEEDS_REVIEW
  GRADED
}


model MathEditorDocument {
  id          String    @id @default(uuid())
  name        String
  head        String?
  data        Json      @db.Json // Assuming data is JSON format
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


model User {
  id            String    @id @default(cuid())
  name          String
  slug          String?   @unique   // 👈 used in URL
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]


  isTeacher   Boolean?
  isAdmin     Boolean?

  jahrgang    String?
  klasse      String?

  userFachExperiences UserFachExperience[] // Add this relation
  awardedPoints AwardedPoints[] // Add this relation
  attachments  Attachment[] // Relation field for attachments to quest

  ownedLearningPaths           LearningPath[]                 @relation("LearningPathOwner")
  learningPathEnrollments      LearningPathEnrollment[]
  learningPathStepCompletions  LearningPathStepCompletion[]
  learningPathCompletions      LearningPathCompletion[]
  exerciseAttempts             ExerciseAttempt[]

  sharedCourses                Course[]                       @relation("CourseShares")

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}



model Course {
  id String @id @default(uuid())
  userId String
  title String @db.Text
  description String? @db.Text
  longDescription String? @db.Text

  slug String? @unique
  fileKey String? @db.Text

  prerequisites String? @db.Text
  vorkenntnisse String? @db.Text
  kompetenzen String? @db.Text
  imageUrl String? @db.Text
  // price Float?
  // level Int?
  schwierigkeit DifficultyLevel? @default(EASY)
  klassenstufe Int?
  isPublished Boolean @default(false)


  // categoryId String?
  // category Category? @relation(fields: [categoryId], references: [id])
  faecher Fach[] // Define the many-to-many relationship with Fach
  categories Category[] // Define the many-to-many relationship with Category

  awardedPoints AwardedPoints[] // Add this relation

  chapters Chapter[]
  exercises Exercise[]
  attachments Attachment[]
  purchases Purchase[]
  // requirements String[] // List of requirements for the course


  gradings Grading[]

  learningPathSteps LearningPathStep[]

  sharedWith User[] @relation("CourseShares")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  // @@fulltext([title])
  // @@map("course")
}

model Chapter {
  id String @id @default(uuid())
  title String
  description String? @db.Text
  descriptionEditor Json? @db.Json
  mathEditor Json? @db.Json // Assuming data is JSON format
  videoUrl String? @db.Text
  position Int
  isPublished Boolean @default(false)
  isFree Boolean @default(false)

  courseId String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  userProgress UserProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  // @@map("chapter")
}

model Exercise {
  id           String   @id @default(uuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title        String
  description  String?  @db.Text
  intro        Json?    @db.Json
  position     Int
  isPublished  Boolean  @default(false)
  isFree       Boolean  @default(false)
  passingScore Int?
  awardXp      Boolean  @default(false)
  questions    ExerciseQuestion[]
  attempts     ExerciseAttempt[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([courseId])
}

model ExerciseQuestion {
  id          String       @id @default(uuid())
  exerciseId  String
  exercise    Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  kind        QuestionKind
  prompt      Json         @db.Json
  spec        Json         @db.Json
  solution    Json         @db.Json
  explanation Json?        @db.Json
  points      Int          @default(1)
  position    Int
  responses   ExerciseResponse[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([exerciseId])
}

model ExerciseAttempt {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  totalScore  Int           @default(0)
  maxScore    Int           @default(0)
  status      AttemptStatus @default(IN_PROGRESS)
  responses   ExerciseResponse[]

  @@unique([userId, exerciseId])
  @@index([exerciseId])
  @@index([userId])
}

model ExerciseResponse {
  id          String           @id @default(uuid())
  attemptId   String
  attempt     ExerciseAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId  String
  question    ExerciseQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer      Json             @db.Json
  autoScore   Int?
  finalScore  Int?
  feedback    Json?
  needsReview Boolean          @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model Attachment {
  id String @id @default(uuid())
  name String
  url String @db.Text

  courseId String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade )

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade )

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  // @@map("attachment")
}

model UserProgress{
  id String @id @default(uuid())
  userId String

  chapterId String
  // chapterId String @unique
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)  

  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
  @@unique([userId, chapterId])
  // @@map("userprogress")
}


model Fach {
  id String @id @default(uuid())
  name String @unique

  userFachExperiences UserFachExperience[] // Add this relation
  awardedPoints AwardedPoints[] // Add this relation

  courses Course[]

  @@index([id]) // Adding index for the fachId relation in UserFachExperience
  // @@map("fach")
}

model Category {
  id String @id @default(uuid())
  name String @unique
  courses Course[]
  // @@map("category")
}




model UserFachExperience {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fachId      String
  fach        Fach     @relation(fields: [fachId], references: [id], onDelete: Cascade)
  experience  Int      @default(0)
  level       Int?     @default(1)  // Add level field to track user level per Fach


  @@unique([userId, fachId]) // Ensure a user can only have one entry per Fach
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId]) // Adding index for userId to optimize querying
  @@index([fachId]) // Adding index for fachId to optimize querying
  // @@map("userfachexperience") 
}


model AwardedPoints {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fachId      String
  fach        Fach     @relation(fields: [fachId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  points      Int
  awardedAt   DateTime @default(now())

  @@unique([userId, fachId, courseId]) // Ensure points are only awarded once per course

  @@index([userId]) // Adding index for userId to optimize querying
  @@index([fachId]) // Adding index for fachId to optimize querying
  @@index([courseId]) // Adding index for fachId to optimize querying
  // @@map("awardedpoints") 
}


model Purchase {
  id String @id @default(uuid())
  userId String

  courseId String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  // @@map("purchase")
}


model Grading {
  id         String  @id @default(uuid())
  userId     String

  points     Int
  points_awarded Boolean @default(false)

  courseId   String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  // @@map("grading")
}



model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String? @db.Text
  imageUrl    String

  userBadges   UserBadge[]
  learningPaths LearningPath[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // @@map("badge")
}

model UserBadge {
  id      String   @id @default(uuid())
  userId  String

  badgeId String
  badge   Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, badgeId], name: "unique_user_badge")
  // @@map("userbadge")
}

model LearningPath {
  id          String             @id @default(uuid())
  title       String             @db.Text
  description String?            @db.Text
  slug        String             @unique
  difficulty  LernpfadDifficulty
  ownerId     String
  owner       User               @relation("LearningPathOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  isPublished Boolean            @default(false)
  badgeId     String?
  badge       Badge?             @relation(fields: [badgeId], references: [id], onDelete: SetNull)
  flowData    Json               @db.Json
  steps       LearningPathStep[]
  enrollments LearningPathEnrollment[]
  completions LearningPathCompletion[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([ownerId])
}

model LearningPathStep {
  id             String                       @id @default(uuid())
  learningPathId String
  learningPath   LearningPath   @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position       Int
  bonusXp        Int            @default(0)
  stepCompletions LearningPathStepCompletion[]

  @@unique([learningPathId, position])
  @@unique([learningPathId, courseId])
  @@index([courseId])
}

model LearningPathEnrollment {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPathId   String
  learningPath     LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  currentStepIndex Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([userId, learningPathId])
  @@index([learningPathId])
}

model LearningPathStepCompletion {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPathStepId String
  learningPathStep   LearningPathStep @relation(fields: [learningPathStepId], references: [id], onDelete: Cascade)
  completedAt        DateTime         @default(now())

  @@unique([userId, learningPathStepId])
  @@index([userId])
}

model LearningPathCompletion {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningPathId String
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())

  @@unique([userId, learningPathId])
  @@index([learningPathId])
}

model FaqEntry {
  id        String   @id @default(uuid())
  question  String   @db.Text
  answer    String   @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}