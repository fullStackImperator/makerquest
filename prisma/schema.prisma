
generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  // output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum DifficultyLevel {
  VERY_EASY
  EASY
  MEDIUM
  DIFFICULT
  VERY_DIFFICULT
}


model MathEditorDocument {
  id          String    @id @default(uuid())
  name        String
  head        String?
  data        Json      @db.Json // Assuming data is JSON format
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


model User {
  id            String    @id @default(cuid())
  name          String
  slug          String?   @unique   // 👈 used in URL
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]


  isTeacher   Boolean?
  isAdmin     Boolean?

  jahrgang    String?
  klasse      String?

  userFachExperiences UserFachExperience[] // Add this relation
  awardedPoints AwardedPoints[] // Add this relation


  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}



model Course {
  id String @id @default(uuid())
  userId String
  title String @db.Text
  description String? @db.Text
  longDescription String? @db.Text

  slug String? @unique
  fileKey String? @db.Text

  prerequisites String? @db.Text
  vorkenntnisse String? @db.Text
  kompetenzen String? @db.Text
  imageUrl String? @db.Text
  // price Float?
  // level Int?
  schwierigkeit DifficultyLevel? @default(EASY)
  klassenstufe Int?
  isPublished Boolean @default(false)


  // categoryId String?
  // category Category? @relation(fields: [categoryId], references: [id])
  faecher Fach[] // Define the many-to-many relationship with Fach
  categories Category[] // Define the many-to-many relationship with Category

  awardedPoints AwardedPoints[] // Add this relation

  chapters Chapter[]
  purchases Purchase[]
  // requirements String[] // List of requirements for the course


  gradings Grading[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  // @@fulltext([title])
  // @@map("course")
}

model Chapter {
  id String @id @default(uuid())
  title String
  description String? @db.Text
  descriptionEditor Json? @db.Json
  mathEditor Json? @db.Json // Assuming data is JSON format
  videoUrl String? @db.Text
  position Int
  isPublished Boolean @default(false)
  isFree Boolean @default(false)

  courseId String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  userProgress UserProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  // @@map("chapter")
}


model UserProgress{
  id String @id @default(uuid())
  userId String

  chapterId String
  // chapterId String @unique
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)  

  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chapterId])
  @@unique([userId, chapterId])
  // @@map("userprogress")
}


model Fach {
  id String @id @default(uuid())
  name String @unique

  userFachExperiences UserFachExperience[] // Add this relation
  awardedPoints AwardedPoints[] // Add this relation

  courses Course[]

  @@index([id]) // Adding index for the fachId relation in UserFachExperience
  // @@map("fach")
}

model Category {
  id String @id @default(uuid())
  name String @unique
  courses Course[]
  // @@map("category")
}




model UserFachExperience {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fachId      String
  fach        Fach     @relation(fields: [fachId], references: [id], onDelete: Cascade)
  experience  Int      @default(0)
  level       Int?     @default(1)  // Add level field to track user level per Fach


  @@unique([userId, fachId]) // Ensure a user can only have one entry per Fach
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId]) // Adding index for userId to optimize querying
  @@index([fachId]) // Adding index for fachId to optimize querying
  // @@map("userfachexperience") 
}


model AwardedPoints {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fachId      String
  fach        Fach     @relation(fields: [fachId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  points      Int
  awardedAt   DateTime @default(now())

  @@unique([userId, fachId, courseId]) // Ensure points are only awarded once per course

  @@index([userId]) // Adding index for userId to optimize querying
  @@index([fachId]) // Adding index for fachId to optimize querying
  @@index([courseId]) // Adding index for fachId to optimize querying
  // @@map("awardedpoints") 
}


model Purchase {
  id String @id @default(uuid())
  userId String

  courseId String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  // @@map("purchase")
}


model Grading {
  id         String  @id @default(uuid())
  userId     String

  points     Int
  points_awarded Boolean @default(false)

  courseId   String
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId])
  // @@map("grading")
}



model Badge {
  id          String   @id @default(uuid())
  name        String   @unique
  description String? @db.Text
  imageUrl    String

  userBadges   UserBadge[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // @@map("badge")
}

model UserBadge {
  id      String   @id @default(uuid())
  userId  String

  badgeId String
  badge   Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, badgeId], name: "unique_user_badge")
  // @@map("userbadge")
}